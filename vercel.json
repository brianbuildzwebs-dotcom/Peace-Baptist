{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "peacebaptist.net" }],
      "destination": "https://www.peacebaptist.net/:path*",
      "permanent": true
    },
    { "source": "/adnin", "destination": "/admin", "permanent": false },
    { "source": "/adnin/:path*", "destination": "/admin", "permanent": false },
    { "source": "/admim", "destination": "/admin", "permanent": false },
    { "source": "/admim/:path*", "destination": "/admin", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/push/cron/daily-walk",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/push/cron/scheduled",
      "schedule": "30 14 * * 0"
    }
  ]
}