{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/push/cron/scheduled",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/push/cron/scheduled",
      "schedule": "30 14 * * 0"
    }
  ]
}