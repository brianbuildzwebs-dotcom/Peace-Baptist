# ── Supabase (required for forms, admin, events) ──
# Create a free project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend (same values — Vite exposes VITE_ prefixed vars)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Email notifications (optional but recommended) ──
# Sign up at https://resend.com — free tier works for testing
RESEND_API_KEY=re_your_key
ADMIN_EMAIL=peacebible@bellsouth.net
FROM_EMAIL=Peace Baptist Church <notifications@peacebaptist.net>
SITE_URL=https://peacebaptist.net

# ── API override (defaults to /api on Vercel) ──
# VITE_API_BASE_URL=/api