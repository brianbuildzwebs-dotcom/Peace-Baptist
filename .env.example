# ── Supabase (required for forms, admin, events) ──
# Create a free project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend (same values — Vite exposes VITE_ prefixed vars)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin MFA: enable TOTP in Supabase Dashboard → Authentication → Multi-Factor

# ── Email notifications (optional but recommended) ──
# Sign up at https://resend.com — free tier works for testing
RESEND_API_KEY=re_your_key
ADMIN_EMAIL=peacebible@bellsouth.net
FROM_EMAIL=Peace Baptist Church <notifications@peacebaptist.net>
# No trailing spaces — use exactly: https://peacebaptist.net
SITE_URL=https://peacebaptist.net

# ── Web push notifications (PWA + Daily Walk) ──
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:peacebible@bellsouth.net
# Vercel Cron auth — use a long random string
CRON_SECRET=your-long-random-cron-secret
# Optional: reveal detailed /api/health fields with Authorization: Bearer <secret>
# HEALTH_DETAIL_SECRET=your-long-random-health-secret

# ── API override (defaults to /api on Vercel) ──
# VITE_API_BASE_URL=/api